DISCORD_TRISHNA_TOKEN=
# Legacy fallback for Trishna if DISCORD_TRISHNA_TOKEN is unset.
DISCORD_TOKEN=
# Optional: use a guild ID during development for faster slash command updates.
DISCORD_GUILD_ID=
# debug, info, warn, error
LOG_LEVEL=info

# Telegram adapter (optional)
TELEGRAM_TRISHNA_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to run commands (required when token is set)
TELEGRAM_OWNER_USER_IDS=
# Optional: comma-separated chat IDs where owner commands may run. Supports negative group/supergroup IDs.
TELEGRAM_ALLOWED_CHAT_IDS=
# Privacy-first default hides IPs in /tgnet. Set true only when actively debugging routing.
TELEGRAM_TGNET_REVEAL_IPS=false
# mtproto (default) or botapi
TELEGRAM_TRANSPORT=mtproto
# Required for MTProto; create at https://my.telegram.org
TELEGRAM_MTPROTO_APP_ID=
TELEGRAM_MTPROTO_APP_HASH=
TELEGRAM_MTPROTO_SESSION_PATH=data/telegram/mtproto-session.json
# MTProxy is enabled by default for privacy/fail-closed routing.
TELEGRAM_MTPROTO_PROXY_ENABLED=true
TELEGRAM_MTPROTO_PROXY_HOST=
TELEGRAM_MTPROTO_PROXY_PORT=
# Required: secured (dd/ee) or TLS cloak MTProxy secret. Simple 16-byte secrets are rejected.
TELEGRAM_MTPROTO_PROXY_SECRET=
# Bot API only: optional local Bot API server, e.g. http://127.0.0.1:8081. Plain HTTP is local/private only.
TELEGRAM_API_BASE_URL=

# YouTube RSS -> Discord webhook (optional; channel skipped if unset)
DISCORD_WEBHOOK_SHNKPLAYS=

# YouTube live chat stream bot (optional; enable after `go run ./cmd/trishna auth youtube`)
YOUTUBE_CHAT_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_TOKEN_PATH=data/youtube-token.json
# Comma-separated YouTube channel IDs that can run owner-only commands like !setgame
YOUTUBE_OWNER_CHANNEL_IDS=
# Optional override for unlisted/private streams when channel /live cannot be discovered
YOUTUBE_LIVE_VIDEO_ID=
STREAMBOT_STATE_PATH=data/streambot/state.json
STREAMBOT_RESPONSES_DIR=data/streambot/responses

# Optional: comma-separated Discord user IDs allowed to run /status (required for trishna)
STATUS_ALLOWED_USER_IDS=

# shawnb — Ollama AI chat bot (SOUL.md personality, gitignored)
DISCORD_SHAWNB_TOKEN=
# Optional dev guild for faster shawnb slash command updates
DISCORD_SHAWNB_GUILD_ID=
# Comma-separated Discord user IDs allowed to chat with shawnb (required)
SHAWNB_ALLOWED_USER_IDS=
# Owner Discord user ID — receives DM alerts for urgent user messages (required)
SHAWNB_OWNER_USER_ID=
# Comma-separated channel IDs where shawnb replies (optional; DMs always work)
# SHAWNB_ALLOWED_CHANNEL_IDS=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
SOUL_MD_PATH=./SOUL.md
SHAWNB_CHAT_LOG_DIR=./data/shawnb/chats
SHAWNB_HEARTBEAT_PATH=data/shawnb/heartbeat.json
# Pending reminders (Asia/Kolkata timezone); optional override
# SHAWNB_REMINDERS_PATH=data/shawnb/reminders.json
SHAWNB_HISTORY_LIMIT=20
